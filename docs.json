          },
          "href": "https://mintlify.com/docs"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://mintlify.com/blog"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Plugin Usage",
        "pages": [
          "welcome",
          "first-install",
          "making-a-menu"
        ]
      },
      {
        "tab": "API Usage",
        "pages": [
          "getting-started",
          "your-first-menu"
        ]
      }
    ]
  },
  "logo": "/logo/sunscreen.svg",
  "navbar": {
    "links": [
      {
        "label": "Discord",
        "href": "https://discord.gg/PJFAGTCyyk"
      },
      {
        "label": "GitHub",
